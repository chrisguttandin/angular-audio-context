{
    "author": "Christoph Guttandin",
    "bugs": {
        "url": "https://github.com/chrisguttandin/angular-audio-context/issues"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "dependencies": {
        "@babel/runtime": "7.29.2",
        "standardized-audio-context": "^25.3.77",
        "tslib": "^2.8.1"
    },
    "description": "An Angular wrapper for the Web Audio API's AudioContext.",
    "devDependencies": {
        "@angular-eslint/builder": "^21.4.0",
        "@angular/build": "^21.2.12",
        "@angular/cli": "^21.2.12",
        "@angular/common": "^21.2.14",
        "@angular/compiler": "^21.2.14",
        "@angular/compiler-cli": "^21.2.14",
        "@angular/core": "^21.2.14",
        "@angular/platform-browser": "^21.2.14",
        "@angular/platform-browser-dynamic": "^21.2.14",
        "@angular/router": "^21.2.14",
        "@babel/core": "7.29.0",
        "@babel/plugin-external-helpers": "^7.27.1",
        "@babel/plugin-transform-runtime": "7.29.0",
        "@babel/preset-env": "7.29.5",
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-angular": "^21.0.1",
        "@rollup/plugin-babel": "^7.0.0",
        "@vitest/browser-webdriverio": "^4.1.7",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^8.57.0",
        "eslint-config-holy-grail": "^62.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "rollup": "^4.60.4",
        "rxjs": "~7.8.2",
        "tsconfig-holy-grail": "^16.0.0",
        "typescript": "~5.9.3",
        "vitest": "^4.1.7",
        "zone.js": "^0.16.2"
    },
    "files": [
        "build/es2019/",
        "build/es5/",
        "src/"
    ],
    "homepage": "https://github.com/chrisguttandin/angular-audio-context",
    "keywords": [
        "Angular",
        "Web Audio API",
        "audio",
        "ngx"
    ],
    "license": "MIT",
    "main": "build/es5/bundle.js",
    "module": "build/es2019/module.js",
    "name": "angular-audio-context",
    "peerDependencies": {
        "@angular/common": "^21.2.11",
        "@angular/core": "^21.2.11"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/chrisguttandin/angular-audio-context.git"
    },
    "scripts": {
        "build": "rimraf build/* && ngc -p src/tsconfig.json && rollup --config config/rollup/bundle.mjs",
        "continuous": "npx ng test",
        "lint": "npm run lint:config && npm run lint:src && npm run lint:test",
        "lint:config": "eslint --config config/eslint/config.json --ext .cjs --ext .js --ext .mjs --report-unused-disable-directives config/",
        "lint:src": "npx ng lint angular-audio-context",
        "lint:test": "npx ng lint angular-audio-context --configuration test",
        "prepare": "husky",
        "prepublishOnly": "npm run build",
        "test": "npm run lint && npm run test:unit",
        "test:unit": "npm run test:unit-chrome && npm run test:unit-firefox && npm run test:unit-safari",
        "test:unit-chrome": "if [ \"$TYPE\" = \"\" -o \"$TYPE\" = \"unit\" ] && [ \"$TARGET\" = \"\" -o \"$TARGET\" = \"chrome\" ]; then npx ng test --browsers chrome --headless true --watch false; fi",
        "test:unit-firefox": "if [ \"$TYPE\" = \"\" -o \"$TYPE\" = \"unit\" ] && [ \"$TARGET\" = \"\" -o \"$TARGET\" = \"firefox\" ]; then npx ng test --browsers firefox --headless true --watch false; fi",
        "test:unit-safari": "if [ \"$TYPE\" = \"\" -o \"$TYPE\" = \"unit\" ] && [ \"$TARGET\" = \"\" -o \"$TARGET\" = \"safari\" ]; then npx ng test --browsers safari --headless false --watch false; fi"
    },
    "types": "build/es2019/module.d.ts",
    "version": "40.0.1"
}
